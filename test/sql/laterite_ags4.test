# Integration tests for the laterite_ags4 extension.
# Run via: make test   (extension-ci-tools drives DuckDB's sqllogictest runner)
#
# Format: https://duckdb.org/dev/sqllogictest/intro.html
#   query I = INTEGER result, query T = VARCHAR, query R = REAL/DOUBLE.
# Expected output must match DuckDB's exact format (LESSONS.md Pitfall P5) —
# verify with `make test` before submitting; the fixture path is relative to the
# repo root (the test runner's CWD).

require laterite_ags4

# read_ags: LOCA has 2 rows.
query I
SELECT count(*) FROM read_ags('test/sql/mini.ags', 'LOCA');
----
2

# Born-typed: a 2DP heading is DOUBLE, an ID heading is VARCHAR.
query T
SELECT typeof(loca_gl) FROM read_ags('test/sql/mini.ags', 'LOCA') LIMIT 1;
----
DOUBLE

query T
SELECT typeof(loca_id) FROM read_ags('test/sql/mini.ags', 'LOCA') LIMIT 1;
----
VARCHAR

# Born-typed value: the string "100.50" arrives as the double 100.5.
query I
SELECT (loca_gl = 100.5)::INTEGER FROM read_ags('test/sql/mini.ags', 'LOCA') WHERE loca_id = 'BH01';
----
1

# Deterministic keys: every SAMP row joins to its LOCA via _parent_id = _id,
# across two independent read_ags calls, with zero orphans.
query I
SELECT count(*) FROM read_ags('test/sql/mini.ags', 'SAMP') s
JOIN read_ags('test/sql/mini.ags', 'LOCA') l ON s._parent_id = l._id;
----
3

query I
SELECT count(*) FROM read_ags('test/sql/mini.ags', 'SAMP') s
LEFT JOIN read_ags('test/sql/mini.ags', 'LOCA') l ON s._parent_id = l._id
WHERE l._id IS NULL;
----
0

# Metadata: 3 groups; LOCA's parent is PROJ.
query I
SELECT count(*) FROM ags_groups('test/sql/mini.ags');
----
3

query T
SELECT parent FROM ags_groups('test/sql/mini.ags') WHERE "group" = 'LOCA';
----
PROJ

# ags_relationships: SAMP's parent is LOCA, sharing LOCA_ID.
query T
SELECT parent FROM ags_relationships() WHERE child = 'SAMP';
----
LOCA

# validate_ags runs and every severity is from the known set (no bad severities).
query I
SELECT count(*) FROM validate_ags('test/sql/mini.ags')
WHERE severity NOT IN ('error', 'warning', 'fyi');
----
0

# --- validate_ags severity knobs (#194) -----------------------------------
# Error-only by default; the WARNING / FYI tiers are opt-in (matching the library
# default + lat-check). fyi_tran.ags has an unrecognised TRAN_AGS, which the
# validator flags as an FYI — surfaced ONLY with fyi := true.
query I
SELECT count(*) FROM validate_ags('test/sql/fyi_tran.ags') WHERE severity = 'fyi';
----
0

query I
SELECT count(*) FROM validate_ags('test/sql/fyi_tran.ags', fyi := true) WHERE severity = 'fyi';
----
1

# The warnings knob shares the same path and is accepted; opting the tiers in never
# drops a finding (monotonic).
query I
SELECT (
  (SELECT count(*) FROM validate_ags('test/sql/fyi_tran.ags', warnings := true, fyi := true))
  >= (SELECT count(*) FROM validate_ags('test/sql/fyi_tran.ags'))
)::INTEGER;
----
1

# --- dict_version := (renamed from edition :=) -----------------------------
# Forcing a bundled edition through the renamed named param runs the check and
# still yields only known severities.
query I
SELECT count(*) FROM validate_ags('test/sql/mini.ags', dict_version := '4.2')
WHERE severity NOT IN ('error', 'warning', 'fyi');
----
0

# certify_ags reports the resolved edition in a `dict_version` column (renamed from
# `edition`). mini.ags has no TRAN_AGS, so it falls back to 4.1.1.
query T
SELECT dict_version FROM certify_ags('test/sql/mini.ags');
----
4.1.1

# read_ags_text: parse AGS4 content passed as a VARCHAR (stable-API path, no VFS).
# Same born-typed output as read_ags — 2 LOCA rows, LOCA_GL typed DOUBLE — but the
# content comes in as an argument (here a literal; a bound parameter at runtime),
# so it needs no virtual filesystem. chr(10) joins avoid blank lines in this file.
query IT
SELECT count(*)::INTEGER, MAX(typeof(loca_gl)) FROM read_ags_text(
'"GROUP","PROJ"' || chr(10) || '"HEADING","PROJ_ID"' || chr(10) ||
'"UNIT",""' || chr(10) || '"TYPE","ID"' || chr(10) || '"DATA","P1"' || chr(10) ||
chr(10) ||
'"GROUP","LOCA"' || chr(10) || '"HEADING","LOCA_ID","LOCA_GL"' || chr(10) ||
'"UNIT","","m"' || chr(10) || '"TYPE","ID","2DP"' || chr(10) ||
'"DATA","BH01","55.20"' || chr(10) || '"DATA","BH02","48.30"', 'LOCA');
----
2	DOUBLE

# --- parse cache (P1) -----------------------------------------------------
# The cache is transparent: every read_ags / ags_groups / load_ags_script call in
# this file re-resolves the same path, so the whole suite already exercises cache
# hits after the first parse. These pin the behaviour the cache is meant to keep
# correct while making it a single parse.

# Three separate reads of one file in one statement — each is its own read_parsed
# call (first parses, the rest hit the cache) — still return the right per-group
# row counts.
query III
SELECT
  (SELECT count(*) FROM read_ags('test/sql/mini.ags', 'PROJ')),
  (SELECT count(*) FROM read_ags('test/sql/mini.ags', 'LOCA')),
  (SELECT count(*) FROM read_ags('test/sql/mini.ags', 'SAMP'));
----
1	2	3

# load_ags_script: 8 statements for mini.ags — PROJ (table + _id index) is root
# so has no _parent_id index; LOCA and SAMP each add one (3 stmts each). Executing
# the script runs one read_ags per group, all served by a single cached parse.
query I
SELECT count(*) FROM load_ags_script('test/sql/mini.ags');
----
8

# The first generated statement is the PROJ table CTAS (file order); its body is
# the now-cache-backed read_ags.
query T
SELECT stmt FROM load_ags_script('test/sql/mini.ags') WHERE seq = 0;
----
CREATE TABLE ags_proj AS SELECT * FROM read_ags('test/sql/mini.ags', 'PROJ');

# --- certify_ags (PR D): mint a `.ags.idx` certificate for a clean file ---
# The positive mint path writes a sibling .idx, so the full lifecycle (mint →
# sliced read → skipped re-validation → freshness gate) lives in the temp-isolated
# Rust e2e (tests/e2e.rs::cert_lifecycle) to keep the repo tree clean. Here we only
# assert the side-effect-FREE refusal path: an invalid file is never certified
# (a certificate asserts clean), so nothing is written.
query I
SELECT certified::INTEGER FROM certify_ags('test/sql/mini.ags');
----
0

# ...and it reports the error count that blocked the mint.
query I
SELECT (errors > 0)::INTEGER FROM certify_ags('test/sql/mini.ags');
----
1
